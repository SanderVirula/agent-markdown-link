{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/runtime/session-start.mjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}\\runtime\\session-start.mjs\"",
            "timeout": 10,
            "statusMessage": "Loading curated context"
          }
        ]
      }
    ]
  }
}
