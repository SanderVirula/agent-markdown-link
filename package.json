{
  "name": "agent-markdown-link-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11",
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.base.json",
    "lint": "eslint . --max-warnings 0",
    "build": "tsc --build packages/core packages/cli && node scripts/package-artifacts.mjs",
    "test:unit": "vitest run packages --passWithNoTests",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:security": "vitest run tests/security --passWithNoTests",
    "validate:schemas": "node scripts/validate-schemas.mjs",
    "validate:plugins": "vitest run tests/contracts/plugin-artifacts.test.ts",
    "package:artifacts": "node scripts/package-artifacts.mjs",
    "test:release": "vitest run tests/contracts/release-readiness.test.ts tests/contracts/shared-skill.test.ts",
    "ci": "npm run typecheck && npm run lint && npm run build && npm run validate:schemas && npm run test:unit && npm run test:integration && npm run test:security && npm run validate:plugins && npm run test:release"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
