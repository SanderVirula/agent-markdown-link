{
  "description": "Load explicitly configured curated Markdown at session start.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/runtime/context-reminder.mjs\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
