{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:agent-markdown-link:schema:config:v1",
  "title": "Agent Markdown Link configuration version 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "vaultRoot", "inboxPath", "captureMode", "projects"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "vaultRoot": { "$ref": "#/definitions/absolutePath" },
    "inboxPath": { "$ref": "#/definitions/vaultRelativePath" },
    "outboxRoot": { "$ref": "#/definitions/absolutePath" },
    "captureMode": { "enum": ["disabled", "explicit"] },
    "writeMode": { "enum": ["outbox", "inbox"] },
    "hookPolicy": { "enum": ["observe", "warn", "enforce"] },
    "limits": { "$ref": "#/definitions/limits" },
    "contextExclusions": {
      "type": "array",
      "items": { "$ref": "#/definitions/vaultRelativePath" },
      "uniqueItems": true
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/project" }
    },
    "obsidian": { "$ref": "#/definitions/obsidian" },
    "logging": { "$ref": "#/definitions/logging" },
    "metrics": { "$ref": "#/definitions/metrics" }
  },
  "definitions": {
    "absolutePath": {
      "type": "string",
      "minLength": 1,
      "anyOf": [
        { "pattern": "^/(?!/)" },
        { "pattern": "^[A-Za-z]:[\\\\/](?![\\\\/])" }
      ]
    },
    "vaultRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:/)(?!.*(?:^|/)\\.{1,2}(?:/|$))[^/\\\\\\u0000]+(?:/[^/\\\\\\u0000]+)*$"
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hookInputBytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
        "hookOutputBytes": { "type": "integer", "minimum": 1, "maximum": 4194304 },
        "contextFileBytes": { "type": "integer", "minimum": 1, "maximum": 1048576 },
        "contextTotalBytes": { "type": "integer", "minimum": 1, "maximum": 4194304 },
        "candidateBytes": { "type": "integer", "minimum": 1, "maximum": 1048576 },
        "subprocessOutputBytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
        "subprocessTimeoutMs": { "type": "integer", "minimum": 100, "maximum": 60000 }
      }
    },
    "projectLimits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contextFileBytes": { "type": "integer", "minimum": 1, "maximum": 1048576 },
        "contextTotalBytes": { "type": "integer", "minimum": 1, "maximum": 4194304 }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectId", "workspaceRoots", "contextFiles"],
      "properties": {
        "projectId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "workspaceRoots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/absolutePath" }
        },
        "contextFiles": {
          "type": "array",
          "items": { "$ref": "#/definitions/vaultRelativePath" }
        },
        "searchRoots": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/vaultRelativePath" }
        },
        "contextExclusions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/vaultRelativePath" }
        },
        "limits": { "$ref": "#/definitions/projectLimits" }
      }
    },
    "obsidian": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executable": {
          "type": "string",
          "minLength": 1,
          "anyOf": [
            { "$ref": "#/definitions/absolutePath" },
            { "pattern": "^(?!\\.{1,2}$)[^\\\\/\\u0000]+$" }
          ]
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxBytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
        "maxFiles": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
